{
    "name": "craft-platform",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev --filter=@craft/frontend --filter=@craft/backend",
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\""
    },
    "devDependencies": {
        "@fast-check/vitest": "^0.4.1",
        "@turbo/gen": "^1.11.2",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "fast-check": "^4.6.0",
        "prettier": "^3.1.1",
        "turbo": "^1.11.2",
        "typescript": "^5.3.3"
    },
    "packageManager": "npm@10.2.4",
    "engines": {
        "node": ">=18.0.0"
    }
}
